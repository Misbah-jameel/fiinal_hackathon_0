# AI Employee — Gold Tier Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.

# ------------------------------------------------------------------
# SAFETY FLAG — set to "false" only when ready for real actions
# ------------------------------------------------------------------
DRY_RUN=true

# ------------------------------------------------------------------
# Vault Path
# ------------------------------------------------------------------
VAULT_PATH=D:/fiinal_hackathon_0/AI_Employee_Vault

# ------------------------------------------------------------------
# Gmail (Watcher + Email MCP)
# ------------------------------------------------------------------
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json

# ------------------------------------------------------------------
# LinkedIn (LinkedIn Watcher + LinkedIn Poster)
# ------------------------------------------------------------------
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ------------------------------------------------------------------
# Facebook & Instagram  (Gold Tier)
# Setup guide: python watchers/facebook_watcher.py --vault ./AI_Employee_Vault --auth
#
# FACEBOOK:
#   1. developers.facebook.com → Create App (Business)
#   2. Add "Pages API" → generate long-lived Page Access Token
#   3. Page ID: facebook.com/<your-page> → About → Page ID
#
# INSTAGRAM:
#   1. Connect Instagram Business Account to your Facebook Page
#   2. In Facebook App → add "Instagram Graph API"
#   3. Generate token with: instagram_basic, instagram_manage_comments
#   4. Instagram User ID: GET /me?fields=id via Graph API Explorer
# ------------------------------------------------------------------
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ------------------------------------------------------------------
# Odoo Community  (Gold Tier)
# Start with Docker: docker compose up -d
# Then open http://localhost:8069 and create database "ai_employee"
# ------------------------------------------------------------------
ODOO_URL=http://localhost:8069
ODOO_DB=ai_employee
ODOO_USER=admin
ODOO_PASSWORD=admin

# ------------------------------------------------------------------
# Banking API  (optional — future expansion)
# ------------------------------------------------------------------
BANK_API_TOKEN=
